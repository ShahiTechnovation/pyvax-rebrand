*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Testing / Coverage ────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Virtual environments ─────────────────────────────
.venv/
venv/
env/

