# ╔══════════════════════════════════════════════════════════════════╗
# ║  Project Classified — Environment Variables                     ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in the values.
# The agent reads API keys from environment variables (never from config files).
#
# Usage:
#   cp .env.example .env
#   # edit .env with your keys
#   source .env   (Linux/Mac)
#   # or set them in your shell on Windows

# ── LLM API Key ──────────────────────────────────────────────────
# Required. Your Anthropic (or OpenAI) API key.
# The env var name must match [llm].api_key_env in classified.toml.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional: OpenAI (if using provider = "openai") ──────────────
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Optional: Custom wallet private key ──────────────────────────
# Only needed for pyvax_local backend.
# WARNING: Never commit this file with real keys!
# PYVAX_PRIVATE_KEY=0x...

# ── Optional: Synthesis hackathon ─────────────────────────────────
# SYNTHESIS_API_KEY=your-synthesis-key
